# Mac 中央服务器示例；请替换为本机的绝对路径。
BOOK_VIDEO_PROJECT_ROOT=/Users/your-name/Book-Video-Factory/platform
DATA_DIR=/Users/your-name/Library/Application Support/BookVideoFactory/data

# 抖音解析和无水印视频下载
TIKHUB_API_KEY=
TIKHUB_BASE_URL=https://api.tikhub.io

# 至少配置一种 ASR
ASR_API_KEY=
ASR_BASE_URL=https://api.openai.com/v1
ASR_MODEL=whisper-1
# 本地 whisper.cpp（配置后无需上传音视频）
# WHISPER_CLI_BIN=F:/Codex/tools/whisper.cpp/v1.9.1/Release/whisper-cli.exe
# ASR_MODEL_PATH=F:/Codex/models/whisper.cpp/ggml-small.bin
# TENCENT_SECRET_ID=
# TENCENT_SECRET_KEY=
# TENCENT_ASR_REGION=ap-guangzhou

# 清洗与爆款结构分析，至少配置一种
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_CONFIG_FILE=E:/BaiduNetdiskWorkspace/电脑其他文件同步/视频号/配置/DeepSeek.txt

# 仅供本地界面联调。正式任务禁止开启。
ALLOW_MOCK_PROVIDERS=0

# Windows GPU/TTS Worker。Windows 服务启动后填入其局域网或 Tailscale 地址。
INDEX_TTS2_URL=
INDEX_TTS2_ASYNC=1
INDEX_TTS2_JOB_TIMEOUT_MS=900000
INDEX_TTS2_REQUEST_TIMEOUT_MS=30000
INDEX_TTS2_TIMEOUT_MS=120000
INDEX_TTS2_POLL_MS=3000
INDEX_TTS2_VOICE=常用
