{
  "referenceAcquisition": {
    "provider": "TikHub",
    "apiKeyEnv": "TIKHUB_API_KEY",
    "baseUrlEnv": "TIKHUB_BASE_URL",
    "baseUrlDefault": "https://api.tikhub.io",
    "douyinEndpoint": "/api/v1/douyin/web/fetch_one_video",
    "maxAttempts": 3,
    "allowImplicitFallback": false,
    "videoFilename": "reference-YYYY-MM-DD.mp4",
    "metadataPath": "video_clips/reference-metadata.json"
  },
  "projectRoot": "E:/BaiduNetdiskWorkspace/电脑其他文件同步/视频号/AI视频",
  "fixedIntro": "固定/女版前3秒固定开头.mp4",
  "introVariantDefault": "female",
  "introVariants": {
    "male": {
      "label": "男版片头",
      "path": "固定/男版前3秒固定开头.mp4",
      "sha256": "151357AE9640CC19BA67B6F057FE2ECE0C022298176044E16FE70DED68D0C3D2",
      "durationSeconds": 2.97,
      "requiredVoiceVariant": "male"
    },
    "female": {
      "label": "女版片头",
      "path": "固定/女版前3秒固定开头.mp4",
